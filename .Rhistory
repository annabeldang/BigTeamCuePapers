# Install packages
source("setup.R")
# Create folder
dir.create("BT_NT_PDFs", showWarnings = FALSE)
dir.create("papers", showWarnings = FALSE)
# Function to sanitize text for LaTeX
sanitize_latex <- function(x) {
if (is.na(x) || x == "") return("")
# Escape LaTeX special chars
x <- gsub("(?<!\\\\)%", "\\\\%", x, perl = TRUE)
x <- gsub("_", "\\\\_", x, fixed = TRUE)
x <- gsub("&", "\\\\&", x, fixed = TRUE)
x <- gsub("#", "\\\\#", x, fixed = TRUE)
x <- gsub("\\$", "\\\\$", x)
x <- gsub("â€ ", "--", x)
# Optional: replace en/em dashes
x <- gsub("\u2013", "--", x, fixed = TRUE)
x <- gsub("\u2014", "---", x, fixed = TRUE)
return(x)
}
bt_nt_df <- read_csv(here(
"Study 2/data/big-team",
"BT_final_latex.csv"
)) %>%
select(display_name_final, abstract_final)
for (i in 1:2) {
title <- sanitize_latex(bt_nt_df$display_name_final[i])
abstract <- sanitize_latex(bt_nt_df$abstract_final[i])
latex_text <- paste0(
"\\documentclass[15pt]{article}\n",
"\\usepackage{textcomp}\n",
"\\setlength{\\oddsidemargin}{-0.25in}\n",
"\\setlength{\\evensidemargin}{-0.25in}\n",
"\\setlength{\\textwidth}{7in}\n",
"\\setlength{\\topmargin}{-0.5in}\n",
"\\setlength{\\textheight}{9.5in}\n",
"\\title{", title, "}\n",
"\\date{}\n",
"\\begin{document}\n",
"\\maketitle\n\n",
"\\begin{abstract}\n",
abstract,
"\n\\end{abstract}\n\n",
"\\end{document}\n"
)
base_name <- sprintf("paper_%02d", i)
tex_file <- file.path("BT_NT_PDFs", paste0(base_name, ".tex"))
writeLines(latex_text, tex_file)
system2(
"xelatex",
args = c("-interaction=nonstopmode", "-output-directory=BT_NT_PDFs", tex_file)
)
unlink(file.path("BT_NT_PDFs", paste0(base_name, c(".aux", ".log", ".out", ".tex"))))
}
file.rename("BT_NT_PDFs", file.path("papers", "BT_NT_PDFs"))
# Create folder
dir.create("BT_NT_PDFs", showWarnings = FALSE)
dir.create("papers", showWarnings = FALSE)
